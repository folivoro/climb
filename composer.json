{
    "name": "folivoro/climb",
    "description": "Modernize Sloth projects to the latest version.",
    "keywords": ["sloth", "folivoro", "wordpress", "modernizer", "migration"],
    "homepage": "https://github.com/folivoro/climb",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/folivoro/climb/issues",
        "source": "https://github.com/folivoro/climb"
    },
    "authors": [
        {
            "name": "folivoro",
            "email": "hello@folivoro.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "composer/composer": "^2.9",
        "ergebnis/composer-normalize": "^2.52",
        "ergebnis/json-normalizer": "^4.9",
        "laravel-zero/framework": "^12.0.2",
        "nikic/php-parser": "^5.0",
        "rector/rector": "^2.4",
        "symfony/var-exporter": "^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": [
        "climb"
    ]
}
